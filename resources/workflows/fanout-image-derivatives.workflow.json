{
  "schema": "workflow.document/v1alpha1",
  "version": 1,
  "meta": {
    "id": "fanout-image-derivatives",
    "title": "Fanout Image Derivatives",
    "summary": "Create one image and branch it into direct preview, upscale, and image-to-video derivative outputs.",
    "tags": [
      "demo",
      "fanout",
      "image2video",
      "image_upscale"
    ],
    "difficulty": "intermediate",
    "intendedShowcase": "One-to-many branching from a single generated image.",
    "createdWith": {
      "app": "workflow-studio-web",
      "cliVersion": null,
      "wrapperVersion": null
    },
    "requirements": {
      "nodeTypes": [
        "image2video",
        "image_upscale",
        "input_text",
        "output_image",
        "output_video",
        "text2image"
      ],
      "cliVersion": null,
      "wrapperVersion": null
    }
  },
  "viewport": {
    "x": -40,
    "y": 10,
    "zoom": 0.82
  },
  "groups": [
    {
      "id": "sources",
      "label": "Sources",
      "nodeIds": [
        "prompt",
        "motion_prompt"
      ],
      "color": "#dcff39"
    },
    {
      "id": "main-branch",
      "label": "Main Branch",
      "nodeIds": [
        "generator",
        "preview"
      ],
      "color": "#1fe0f2"
    },
    {
      "id": "derivatives",
      "label": "Derivatives",
      "nodeIds": [
        "upscale",
        "upscale_output",
        "video_branch",
        "video_output"
      ],
      "color": "#ef8ae8"
    }
  ],
  "nodes": [
    {
      "id": "prompt",
      "nodeType": "input_text",
      "position": {
        "x": 70,
        "y": 90
      },
      "label": "Master Prompt",
      "params": {},
      "values": {
        "text": "A silver ring on smoked glass with elegant luxury reflections, hero product composition."
      }
    },
    {

      "targetHandle": "image"
    },
    {
      "id": "e5",
      "source": "generator",
      "sourceHandle": "image",
      "target": "video_branch",
      "targetHandle": "image"
    },
    {
      "id": "e6",
      "source": "motion_prompt",
      "sourceHandle": "text",
      "target": "video_branch",
      "targetHandle": "prompt"
    },
    {
      "id": "e7",
      "source": "video_branch",

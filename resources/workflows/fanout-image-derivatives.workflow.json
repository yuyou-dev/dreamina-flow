      "nodeType": "text2image",
      "position": {
        "x": 420,
        "y": 80
      },
      "label": "Hero Generator",
      "params": {
        "ratio": "16:9",
        "resolution_type": "2k",
        "model_version": "3.1",
        "poll": 180
      },
      "values": {}
    },
    {
      "id": "preview",
      "nodeType": "output_image",
      "position": {
        "x": 770,
        "y": 10
      },
      "label": "Base Preview",
      "params": {},
      "values": {}
    },
    {
      "id": "upscale",
      "nodeType": "image_upscale",
      "position": {
        "x": 770,
        "y": 180
      },
      "label": "Upscale Branch",
      "params": {
        "resolution_type": "4k",
        "poll": 180
      },
      "values": {}
    },
    {
      "id": "upscale_output",
      "nodeType": "output_image",
      "position": {
        "x": 1110,
        "y": 180
      },
      "label": "Upscaled Preview",
      "params": {},
      "values": {}
    },
    {
      "id": "motion_prompt",
      "nodeType": "input_text",
      "position": {
        "x": 770,
        "y": 420
      },
      "label": "Motion Prompt",
      "params": {},

        "text": "Turn the hero shot into a slow parallax move with subtle luxury reflections and shallow depth of field."
      }
    },
    {
      "id": "video_branch",
      "nodeType": "image2video",
      "position": {
        "x": 1110,
        "y": 330
      },
      "label": "Video Branch",
      "params": {
        "duration": 5,
        "video_resolution": "1080p",
        "model_version": "3.0",
        "poll": 180
      },
      "values": {}
    },
    {
      "id": "video_output",
      "nodeType": "output_video",
      "position": {
        "x": 1470,
        "y": 350
      },
      "label": "Video Preview",
      "params": {},
      "values": {}
    }
